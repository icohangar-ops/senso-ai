# Auth0 FGA configuration
# Copy this file to .env and fill in real values. Never commit .env.
# When AUTH0_FGA_API_TOKEN is unset, the client runs in simulated (in-memory) mode.

AUTH0_FGA_API_URL=https://api.us1.fga.dev
AUTH0_FGA_API_TOKEN=your-api-token
AUTH0_FGA_STORE_ID=your-store-id

# Airbyte AI Agents SDK configuration
# Obtain credentials from https://portal.airbyte.com
AIRBYTE_CLIENT_ID=your-airbyte-client-id
AIRBYTE_CLIENT_SECRET=your-airbyte-client-secret

# Source-specific configuration (optional — can also be passed programmatically)
# Notion
NOTION_DATABASE_ID=
NOTION_CONNECTOR_ID=

# Confluence
CONFLUENCE_SPACE=
CONFLUENCE_CONNECTOR_ID=

# GitHub
GH_OWNER=
GH_REPO=
GH_CONNECTOR_ID=

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CONNECTOR_ID=

# Airtable
AIRTABLE_BASE_ID=
AIRTABLE_CONNECTOR_ID=
